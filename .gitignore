# --------------------------------------------------------------------
# Project-specific ignore rules — KEEP IN SYNC with docs and README
# --------------------------------------------------------------------

# Temporary files and local logs (tracked logs/README.md is NOT ignored)
*.tmp
*.bak
*.swp
*.swo

# Log files generated by local verification commands — NOT committed
logs/*.log
logs/*.summary.txt
logs/*.console.txt
logs/teammate-verify-console-*.out
logs/teammate-verify-console-*.err
# TA-collected student summary files (grade-summaries.sh input) — NOT committed.
# Note: logs/*.summary.txt above only matches direct children, so the
# collection subdirectory needs its own rule.
logs/student-summaries/
!logs/README.md

# Archives and large binary deliverables — NOT committed
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.mp4
*.mov
*.avi
*.mkv

# Screenshots and submission asset bundles — NOT committed
screenshots/
submission_assets/
proj54_submission_assets/

# Sensitive or non-repository materials
报名材料/
提交备份/
评审与提示词/
参考资料/

# Sensitive local files — NEVER commit
*.env
*.token
*_token_*
*_secret_*
*password*
local.properties

# Third-party baselines under external/ are NOT committed as plain source.
# Keep external/ docs (README and notes), but ignore any cloned/downloaded
# source trees (e.g. external/xv6-riscv/). If a git submodule is used instead,
# its gitlink is tracked regardless of this rule. See external/README.md.
external/*/
external/xv6-riscv/
!external/README.md
!external/*.md

# Build logs generated from real local commands are NOT committed.
logs/*.log
logs/teammate-verify-*.summary.txt
logs/teammate-verify-console-*.out
logs/teammate-verify-console-*.err
!logs/README.md
