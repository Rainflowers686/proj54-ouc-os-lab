diff --git a/kernel/file.c b/kernel/file.c
index 13a4e69..9857b4f 100644
--- a/kernel/file.c
+++ b/kernel/file.c
@@ -25,6 +25,22 @@ fileinit(void)
   initlock(&ftable.lock, "ftable");
 }
 
+int
+filecount(void)
+{
+  struct file *f;
+  int count = 0;
+
+  acquire(&ftable.lock);
+  for (f = ftable.file; f < ftable.file + NFILE; f++) {
+    if (f->ref > 0)
+      count++;
+  }
+  release(&ftable.lock);
+
+  return count;
+}
+
 // Allocate a file structure.
 struct file *
 filealloc(void)
