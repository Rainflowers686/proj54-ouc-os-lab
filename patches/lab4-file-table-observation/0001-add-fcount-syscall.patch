diff --git a/user/fcounttest.c b/user/fcounttest.c
new file mode 100644
index 0000000..250f928
--- /dev/null
+++ b/user/fcounttest.c
@@ -0,0 +1,49 @@
+#include "kernel/types.h"
+#include "kernel/fcntl.h"
+#include "user/user.h"
+
+static void
+fail(char *msg)
+{
+  printf("fcounttest FAIL: %s\n", msg);
+  exit(1);
+}
+
+int
+main(void)
+{
+  int before;
+  int after_open;
+  int after_close;
+  int fd;
+
+  unlink("fcnttmp");
+
+  before = fcount();
+  fd = open("fcnttmp", O_CREATE | O_RDWR);
+  if (fd < 0)
+    fail("open fcnttmp failed");
+
+  after_open = fcount();
+  if (write(fd, "x", 1) != 1) {
+    close(fd);
+    unlink("fcnttmp");
+    fail("write failed");
+  }
+
+  close(fd);
+  after_close = fcount();
+  unlink("fcnttmp");
+
+  printf("fcount(before) = %d\n", before);
+  printf("fcount(after_open) = %d\n", after_open);
+  printf("fcount(after_close) = %d\n", after_close);
+
+  if (after_open - before != 1)
+    fail("expected global file table delta after open 1");
+  if (after_close != before)
+    fail("expected global file table count to return after close");
+
+  printf("fcounttest done\n");
+  exit(0);
+}
