diff --git a/kernel/fdinfo.h b/kernel/fdinfo.h
new file mode 100644
index 0000000..b42dcf4
--- /dev/null
+++ b/kernel/fdinfo.h
@@ -0,0 +1,9 @@
+// fdinfo: read-only observation of one open file descriptor of the calling
+// process. Filled by sys_fdinfo() and copied out to user space. It exposes
+// only descriptor-level metadata, never a path, inode number, or file content.
+struct fdinfo {
+  int type;      // struct file type (FD_NONE/FD_PIPE/FD_INODE/FD_DEVICE)
+  int readable;  // 1 if the fd is readable
+  int writable;  // 1 if the fd is writable
+  int ref;       // struct file reference count (observation only)
+};
diff --git a/kernel/file.c b/kernel/file.c
index 13a4e69..9b66fc3 100644
--- a/kernel/file.c
+++ b/kernel/file.c
@@ -101,6 +101,18 @@ filestat(struct file *f, uint64 addr)
   return -1;
 }
 
+// Read descriptor-level metadata of f under ftable.lock (observation only).
+void
+fileinfo(struct file *f, int *type, int *readable, int *writable, int *ref)
+{
+  acquire(&ftable.lock);
+  *type = f->type;
+  *readable = f->readable;
+  *writable = f->writable;
+  *ref = f->ref;
+  release(&ftable.lock);
+}
+
 // Read from file f.
 // addr is a user virtual address.
 int
