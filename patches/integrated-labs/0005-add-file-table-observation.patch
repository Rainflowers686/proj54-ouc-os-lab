diff --git a/user/fcounttest.c b/user/fcounttest.c
new file mode 100644
index 0000000..b961046
--- /dev/null
+++ b/user/fcounttest.c
@@ -0,0 +1,39 @@
+#include "kernel/types.h"
+#include "kernel/fcntl.h"
+#include "user/user.h"
+
+int
+main(void)
+{
+  int before;
+  int after_open;
+  int after_close;
+  int fd;
+
+  unlink("fcnttmp");
+
+  before = fcount();
+  fd = open("fcnttmp", O_CREATE | O_RDWR);
+  if (fd < 0) {
+    printf("fcounttest: open fcnttmp failed\n");
+    exit(1);
+  }
+
+  after_open = fcount();
+  if (write(fd, "x", 1) != 1) {
+    printf("fcounttest: write failed\n");
+    close(fd);
+    unlink("fcnttmp");
+    exit(1);
+  }
+
+  close(fd);
+  after_close = fcount();
+  unlink("fcnttmp");
+
+  printf("fcount(before) = %d\n", before);
+  printf("fcount(after_open) = %d\n", after_open);
+  printf("fcount(after_close) = %d\n", after_close);
+  printf("fcounttest done\n");
+  exit(0);
+}
