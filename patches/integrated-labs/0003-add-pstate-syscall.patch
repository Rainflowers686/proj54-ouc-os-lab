diff --git a/kernel/sysproc.c b/kernel/sysproc.c
index 8ac20d9..93e3e38 100644
--- a/kernel/sysproc.c
+++ b/kernel/sysproc.c
@@ -7,6 +7,8 @@
 #include "proc.h"
 #include "vm.h"
 
+extern struct proc proc[NPROC];
+
 uint64
 sys_exit(void)
 {
@@ -124,3 +126,29 @@ sys_add2(void)
   argint(1, &b);
   return a + b;
 }
+
+// Look up one process by pid and return its current enum procstate value.
+// Each proc entry has its own lock. Release it before every return.
+uint64
+sys_pstate(void)
+{
+  int pid;
+  struct proc *p;
+  int state = -1;
+
+  argint(0, &pid);
+  if (pid < 0)
+    return -1;
+
+  for (p = proc; p < &proc[NPROC]; p++) {
+    acquire(&p->lock);
+    if (p->pid == pid && p->state != UNUSED) {
+      state = p->state;
+      release(&p->lock);
+      return state;
+    }
+    release(&p->lock);
+  }
+
+  return -1;
+}
diff --git a/user/labproc.h b/user/labproc.h
new file mode 100644
index 0000000..9553e57
--- /dev/null
+++ b/user/labproc.h
@@ -0,0 +1,32 @@
+// Shared user-side names for xv6 process states used by Lab2 tests.
+//
+// xv6 keeps enum procstate in kernel/proc.h, which is a kernel-internal
+// header. The tests only need stable names for printed observations, so keep
+// this tiny mirror in user space instead of including kernel/proc.h.
+#define LAB_PROC_UNUSED   0
+#define LAB_PROC_USED     1
+#define LAB_PROC_SLEEPING 2
+#define LAB_PROC_RUNNABLE 3
+#define LAB_PROC_RUNNING  4
+#define LAB_PROC_ZOMBIE   5
+
+static char *
+lab_proc_state_name(int state)
+{
+  switch (state) {
+  case LAB_PROC_UNUSED:
+    return "UNUSED";
+  case LAB_PROC_USED:
+    return "USED";
+  case LAB_PROC_SLEEPING:
+    return "SLEEPING";
+  case LAB_PROC_RUNNABLE:
+    return "RUNNABLE";
+  case LAB_PROC_RUNNING:
+    return "RUNNING";
+  case LAB_PROC_ZOMBIE:
+    return "ZOMBIE";
+  default:
+    return "UNKNOWN";
+  }
+}
diff --git a/user/pstatetest.c b/user/pstatetest.c
new file mode 100644
index 0000000..a727fec
--- /dev/null
+++ b/user/pstatetest.c
@@ -0,0 +1,18 @@
+#include "kernel/types.h"
+#include "user/labproc.h"
+#include "user/user.h"
+
+int
+main(void)
+{
+  int pid = getpid();
+  int state = pstate(pid);
+
+  if (state < 0) {
+    printf("pstate(self) failed for pid %d\n", pid);
+    exit(1);
+  }
+
+  printf("pstate(self) = %d (%s)\n", state, lab_proc_state_name(state));
+  exit(0);
+}
