+uint64
+sys_pgcount(void)
+{
+  struct proc *p = myproc();
+  // p->sz is address-space size. uvmpagecount() counts present user mappings.
+  return uvmpagecount(p->pagetable, p->sz);
+}
diff --git a/kernel/vm.c b/kernel/vm.c
index 6bc3730..a83e258 100644
--- a/kernel/vm.c
+++ b/kernel/vm.c
@@ -259,6 +259,21 @@ uvmdealloc(pagetable_t pagetable, uint64 oldsz, uint64 newsz)
   return newsz;
 }
 
+// Count mapped user pages below sz without modifying the page table.
+int
+uvmpagecount(pagetable_t pagetable, uint64 sz)
+{
+  int count = 0;
+
+  for (uint64 va = 0; va < sz; va += PGSIZE) {
+    pte_t *pte = walk(pagetable, va, 0);
+    if (pte != 0 && (*pte & PTE_V) && (*pte & PTE_U))
+      count++;
+  }
+
+  return count;
+}
+
 // Recursively free page-table pages.
 // All leaf mappings must already have been removed.
 void
diff --git a/user/pgcounttest.c b/user/pgcounttest.c
new file mode 100644
index 0000000..bf98786
--- /dev/null
+++ b/user/pgcounttest.c
@@ -0,0 +1,114 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "kernel/riscv.h"
+#include "user/user.h"
+
+static void
+fail(char *msg)
+{
+  printf("pgcounttest FAIL: %s\n", msg);
+  exit(1);
+}
+
+static void
+align_break(void)
+{
+  uint64 current = (uint64)sbrk(0);
+  uint64 aligned = PGROUNDUP(current);
+
+  if (aligned != current) {
+    if (sbrk(aligned - current) == (char *)-1)
+      fail("sbrk align failed");
+  }
+}
+
+// xv6 sbrk() allocates physical pages immediately in the baseline kernel.
+// pgcount should therefore grow as soon as the address space grows.
+static void
+test_eager(void)
+{
+  int before;
+  int after_alloc;
+  int after_free;
+  int delta;
+  char *base;
+
+  align_break();
+
+  before = pgcount();
+  base = sbrk(2 * PGSIZE);
+  if (base == (char *)-1)
+    fail("sbrk eager allocation failed");
+
+  after_alloc = pgcount();
+  delta = after_alloc - before;
+  printf("pgcount eager delta = %d\n", delta);
+
+  if (delta != 2)
+    fail("expected eager delta 2");
+
+  if (sbrk(-2 * PGSIZE) == (char *)-1)
+    fail("sbrk eager free failed");
+
+  after_free = pgcount();
+  printf("pgcount eager delta after free = %d\n", after_free - before);
+}
+
+// sbrklazy() reserves virtual address space and maps pages only when touched.
+// This test separates "address exists" from "PTE_V && PTE_U mapping exists".
+static void
+test_lazy(void)
+{
+  int before;
+  int after_alloc;
+  int after_touch_one;
+  int after_touch_two;
+  int delta_before_touch;
+  int delta_after_one;
+  int delta_after_two;
+  char *base;
+
+  align_break();
+
+  before = pgcount();
+  base = sbrklazy(2 * PGSIZE);
+  if (base == (char *)-1)
+    fail("sbrklazy allocation failed");
+
+  after_alloc = pgcount();
+  delta_before_touch = after_alloc - before;
+  printf("pgcount lazy delta before touch = %d\n", delta_before_touch);
+
+  if (delta_before_touch != 0)
+    fail("expected lazy delta before touch 0");
+
+  base[0] = 1;
+  after_touch_one = pgcount();
+  delta_after_one = after_touch_one - before;
+  printf("pgcount lazy delta after one touch = %d\n", delta_after_one);
+
+  if (delta_after_one != 1)
+    fail("expected lazy delta after one touch 1");
+
+  base[PGSIZE] = 1;
+  after_touch_two = pgcount();
+  delta_after_two = after_touch_two - before;
+  printf("pgcount lazy delta after two touches = %d\n", delta_after_two);
+
+  if (delta_after_two != 2)
+    fail("expected lazy delta after two touches 2");
+
+  if (sbrk(-2 * PGSIZE) == (char *)-1)
+    fail("sbrk lazy free failed");
+
+  printf("pgcount lazy delta after free = %d\n", pgcount() - before);
+}
+
+int
+main(int argc, char *argv[])
+{
+  test_eager();
+  test_lazy();
+  printf("pgcounttest done\n");
+  exit(0);
+}
