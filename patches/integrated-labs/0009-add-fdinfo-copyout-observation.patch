 // Fetch the nth word-sized system call argument as a file descriptor
 // and return both the descriptor and the corresponding struct file.
@@ -139,6 +140,32 @@ sys_fdcount(void)
   return count;
 }
 
+// Lab4 advanced (integrated 0009): read-only observation of one open fd of the
+// calling process. Returns descriptor-level metadata (type/readable/writable/ref)
+// via copyout. Returns -1 for a bad/closed fd or a bad user pointer. It never
+// exposes a path, inode number, or file content.
+uint64
+sys_fdinfo(void)
+{
+  int fd;
+  uint64 uaddr;
+  struct proc *p = myproc();
+  struct file *f;
+  struct fdinfo info;
+
+  argint(0, &fd);
+  argaddr(1, &uaddr);
+
+  if (fd < 0 || fd >= NOFILE || (f = p->ofile[fd]) == 0)
+    return -1;
+
+  fileinfo(f, &info.type, &info.readable, &info.writable, &info.ref);
+
+  if (copyout(p->pagetable, uaddr, (char *)&info, sizeof(info)) < 0)
+    return -1;
+  return 0;
+}
+
 // Create the path new as a link to the same inode as old.
 uint64
 sys_link(void)
diff --git a/user/fdinfotest.c b/user/fdinfotest.c
new file mode 100644
index 0000000..ca2c0f3
--- /dev/null
+++ b/user/fdinfotest.c
@@ -0,0 +1,71 @@
+#include "kernel/types.h"
+#include "kernel/fcntl.h"
+#include "kernel/fdinfo.h"
+#include "user/user.h"
+
+// fdinfotest: Lab4 advanced optional test for the fdinfo() syscall.
+//
+// It verifies, with real syscall results (never hardcoded output):
+//   - fdinfo(open fd) returns 0 with FD_INODE + readable + writable for O_RDWR
+//   - fdinfo(dup fd) also returns 0
+//   - fdinfo(closed fd) returns -1
+//   - fdinfo(bad fd) returns -1
+// Any failed expectation calls fail() which exits with code 1.
+// ref is observed but not strongly asserted (it can vary by environment).
+
+#define FD_INODE 2
+
+static void
+fail(char *msg)
+{
+  printf("fdinfotest FAIL: %s\n", msg);
+  exit(1);
+}
+
+int
+main(void)
+{
+  struct fdinfo a;
+  struct fdinfo b;
+  int fd;
+  int dupfd;
+  int r;
+
+  unlink("fdinfotmp");
+
+  fd = open("fdinfotmp", O_CREATE | O_RDWR);
+  if (fd < 0)
+    fail("open fdinfotmp failed");
+
+  if (fdinfo(fd, &a) != 0)
+    fail("fdinfo on open fd failed");
+  if (a.type != FD_INODE || a.readable != 1 || a.writable != 1)
+    fail("fdinfo open fd fields unexpected");
+  printf("fdinfo open fd ok\n");
+
+  dupfd = dup(fd);
+  if (dupfd < 0)
+    fail("dup failed");
+  if (fdinfo(dupfd, &b) != 0)
+    fail("fdinfo on dup fd failed");
+  if (b.type != FD_INODE || b.readable != 1 || b.writable != 1)
+    fail("fdinfo dup fd fields unexpected");
+  printf("fdinfo dup fd ok\n");
+
+  close(fd);
+  r = fdinfo(fd, &a);
+  printf("fdinfo closed fd = %d\n", r);
+  if (r != -1)
+    fail("closed fd did not return -1");
+
+  r = fdinfo(99, &a);
+  printf("fdinfo bad fd = %d\n", r);
+  if (r != -1)
+    fail("bad fd did not return -1");
+
+  close(dupfd);
+  unlink("fdinfotmp");
+
+  printf("fdinfotest done\n");
+  exit(0);
+}
