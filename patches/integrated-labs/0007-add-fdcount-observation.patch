@@ -125,6 +125,20 @@ sys_fcount(void)
   return filecount();
 }
 
+uint64
+sys_fdcount(void)
+{
+  struct proc *p = myproc();
+  int count = 0;
+
+  for (int fd = 0; fd < NOFILE; fd++) {
+    if (p->ofile[fd] != 0)
+      count++;
+  }
+
+  return count;
+}
+
 // Create the path new as a link to the same inode as old.
 uint64
 sys_link(void)
diff --git a/user/fdcounttest.c b/user/fdcounttest.c
new file mode 100644
index 0000000..45cab49
--- /dev/null
+++ b/user/fdcounttest.c
@@ -0,0 +1,93 @@
+#include "kernel/types.h"
+#include "kernel/fcntl.h"
+#include "user/user.h"
+
+static void
+fail(char *msg)
+{
+  printf("fdcounttest FAIL: %s\n", msg);
+  exit(1);
+}
+
+int
+main(void)
+{
+  int before_fd;
+  int before_file;
+  int after_open_fd;
+  int after_open_file;
+  int after_dup_fd;
+  int after_dup_file;
+  int after_close_one_fd;
+  int after_close_one_file;
+  int after_close_two_fd;
+  int after_close_two_file;
+  int fd;
+  int dupfd;
+
+  unlink("fdcnttmp");
+
+  before_fd = fdcount();
+  before_file = fcount();
+
+  fd = open("fdcnttmp", O_CREATE | O_RDWR);
+  if (fd < 0)
+    fail("open fdcnttmp failed");
+
+  after_open_fd = fdcount();
+  after_open_file = fcount();
+
+  if (write(fd, "x", 1) != 1) {
+    close(fd);
+    unlink("fdcnttmp");
+    fail("write failed");
+  }
+
+  dupfd = dup(fd);
+  if (dupfd < 0) {
+    close(fd);
+    unlink("fdcnttmp");
+    fail("dup failed");
+  }
+
+  after_dup_fd = fdcount();
+  after_dup_file = fcount();
+
+  close(fd);
+  after_close_one_fd = fdcount();
+  after_close_one_file = fcount();
+
+  close(dupfd);
+  after_close_two_fd = fdcount();
+  after_close_two_file = fcount();
+  unlink("fdcnttmp");
+
+  printf("fdcount delta after open = %d\n", after_open_fd - before_fd);
+  printf("fdcount delta after dup = %d\n", after_dup_fd - before_fd);
+  printf("fdcount delta after close one = %d\n", after_close_one_fd - before_fd);
+  printf("fdcount delta after close two = %d\n", after_close_two_fd - before_fd);
+  printf("fcount delta after open = %d\n", after_open_file - before_file);
+  printf("fcount delta after dup = %d\n", after_dup_file - before_file);
+  printf("fcount delta after close one = %d\n", after_close_one_file - before_file);
+  printf("fcount delta after close two = %d\n", after_close_two_file - before_file);
+
+  // fdcount follows per-process fd slots. fcount follows global struct file
+  // objects, so dup(fd) should not allocate another global file entry.
+  if (after_open_fd - before_fd != 1)
+    fail("expected fd delta after open 1");
+  if (after_dup_fd - before_fd != 2)
+    fail("expected fd delta after dup 2");
+  if (after_close_one_fd - before_fd != 1)
+    fail("expected fd delta after close one 1");
+  if (after_close_two_fd - before_fd != 0)
+    fail("expected fd delta after close two 0");
+  if (after_open_file - before_file != 1)
+    fail("expected file delta after open 1");
+  if (after_dup_file - before_file != 1)
+    fail("expected file delta after dup 1");
+  if (after_close_two_file != before_file)
+    fail("expected file count to return after closing both fds");
+
+  printf("fdcounttest done\n");
+  exit(0);
+}
