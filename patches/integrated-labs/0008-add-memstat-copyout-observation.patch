diff --git a/kernel/memstat.h b/kernel/memstat.h
new file mode 100644
index 0000000..39ef7d6
--- /dev/null
+++ b/kernel/memstat.h
@@ -0,0 +1,7 @@
+// memstat: read-only user-address-space observation result.
+// Filled by sys_memstat() and copied out to user space.
+struct memstat {
+  uint64 sz_bytes;    // process memory size (p->sz)
+  int mapped_pages;   // user pages with PTE_V && PTE_U in [0, sz)
+  int page_size;      // PGSIZE
+};
