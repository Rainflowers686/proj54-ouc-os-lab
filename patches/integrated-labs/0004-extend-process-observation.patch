diff --git a/kernel/sysproc.c b/kernel/sysproc.c
index 93e3e38..ea507fc 100644
--- a/kernel/sysproc.c
+++ b/kernel/sysproc.c
@@ -152,3 +152,26 @@ sys_pstate(void)
 
   return -1;
 }
+
+// Count process table entries in one enum procstate. This is a snapshot for
+// teaching; the scheduler may change states immediately after locks release.
+uint64
+sys_pcount(void)
+{
+  int state;
+  struct proc *p;
+  int count = 0;
+
+  argint(0, &state);
+  if (state < UNUSED || state > ZOMBIE)
+    return -1;
+
+  for (p = proc; p < &proc[NPROC]; p++) {
+    acquire(&p->lock);
+    if (p->state == state)
+      count++;
+    release(&p->lock);
+  }
+
+  return count;
+}
diff --git a/user/pchildtest.c b/user/pchildtest.c
new file mode 100644
index 0000000..d380714
--- /dev/null
+++ b/user/pchildtest.c
@@ -0,0 +1,29 @@
+#include "kernel/types.h"
+#include "user/labproc.h"
+#include "user/user.h"
+
+int
+main(void)
+{
+  int child = fork();
+  int status;
+
+  if (child < 0) {
+    printf("pchildtest: fork failed\n");
+    exit(1);
+  }
+
+  if (child == 0) {
+    pause(50);
+    exit(0);
+  }
+
+  pause(2);
+  int state = pstate(child);
+  printf("pstate(child) = %d (%s)\n", state, lab_proc_state_name(state));
+  printf("pstate(-1) = %d\n", pstate(-1));
+
+  kill(child);
+  wait(&status);
+  exit(0);
+}
diff --git a/user/pcounttest.c b/user/pcounttest.c
new file mode 100644
index 0000000..8e7ac96
--- /dev/null
+++ b/user/pcounttest.c
@@ -0,0 +1,14 @@
+#include "kernel/types.h"
+#include "user/labproc.h"
+#include "user/user.h"
+
+int
+main(void)
+{
+  int running = pcount(LAB_PROC_RUNNING);
+  int invalid = pcount(99);
+
+  printf("pcount(RUNNING) = %d\n", running);
+  printf("pcount(99) = %d\n", invalid);
+  exit(0);
+}
