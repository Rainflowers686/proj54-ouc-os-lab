diff --git a/kernel/sysproc.c b/kernel/sysproc.c
index 042854c..d9e896b 100644
--- a/kernel/sysproc.c
+++ b/kernel/sysproc.c
@@ -150,3 +150,24 @@ sys_pstate(void)
 
   return -1;
 }
+
+uint64
+sys_pcount(void)
+{
+  int state;
+  struct proc *p;
+  int count = 0;
+
+  argint(0, &state);
+  if (state < UNUSED || state > ZOMBIE)
+    return -1;
+
+  for (p = proc; p < &proc[NPROC]; p++) {
+    acquire(&p->lock);
+    if (p->state == state)
+      count++;
+    release(&p->lock);
+  }
+
+  return count;
+}
diff --git a/user/pchildtest.c b/user/pchildtest.c
new file mode 100644
index 0000000..701d945
--- /dev/null
+++ b/user/pchildtest.c
@@ -0,0 +1,49 @@
+#include "kernel/types.h"
+#include "user/user.h"
+
+static char *
+state_name(int state)
+{
+  switch (state) {
+  case 0:
+    return "UNUSED";
+  case 1:
+    return "USED";
+  case 2:
+    return "SLEEPING";
+  case 3:
+    return "RUNNABLE";
+  case 4:
+    return "RUNNING";
+  case 5:
+    return "ZOMBIE";
+  default:
+    return "UNKNOWN";
+  }
+}
+
+int
+main(void)
+{
+  int child = fork();
+  int status;
+
+  if (child < 0) {
+    printf("pchildtest: fork failed\n");
+    exit(1);
+  }
+
+  if (child == 0) {
+    pause(50);
+    exit(0);
+  }
+
+  pause(2);
+  int state = pstate(child);
+  printf("pstate(child) = %d (%s)\n", state, state_name(state));
+  printf("pstate(-1) = %d\n", pstate(-1));
+
+  kill(child);
+  wait(&status);
+  exit(0);
+}
diff --git a/user/pcounttest.c b/user/pcounttest.c
new file mode 100644
index 0000000..9af8bf3
--- /dev/null
+++ b/user/pcounttest.c
@@ -0,0 +1,15 @@
+#include "kernel/types.h"
+#include "user/user.h"
+
+#define PROC_STATE_RUNNING 4
+
+int
+main(void)
+{
+  int running = pcount(PROC_STATE_RUNNING);
+  int invalid = pcount(99);
+
+  printf("pcount(RUNNING) = %d\n", running);
+  printf("pcount(99) = %d\n", invalid);
+  exit(0);
+}
