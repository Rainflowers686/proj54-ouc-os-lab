diff --git a/user/pgcounttest.c b/user/pgcounttest.c
new file mode 100644
index 0000000..0a4b2e8
--- /dev/null
+++ b/user/pgcounttest.c
@@ -0,0 +1,105 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "kernel/riscv.h"
+#include "user/user.h"
+
+static void
+fail(const char *msg)
+{
+  printf("pgcounttest FAIL: %s\n", msg);
+  exit(1);
+}
+
+static void
+align_break(void)
+{
+  uint64 cur = (uint64)sbrk(0);
+  uint64 rem = cur % PGSIZE;
+
+  if (rem != 0) {
+    int grow = PGSIZE - rem;
+    if (sbrk(grow) == SBRK_ERROR)
+      fail("align sbrk failed");
+  }
+}
+
+static void
+eager_test(void)
+{
+  int before = pgcount();
+  char *base = sbrk(2 * PGSIZE);
+  if (base == SBRK_ERROR)
+    fail("eager sbrk failed");
+
+  int after_alloc = pgcount();
+  int delta = after_alloc - before;
+
+  printf("pgcount eager before = %d\n", before);
+  printf("pgcount eager after alloc = %d\n", after_alloc);
+  printf("pgcount eager delta = %d\n", delta);
+
+  if (delta != 2)
+    fail("eager delta is not 2");
+
+  if (sbrk(-2 * PGSIZE) == SBRK_ERROR)
+    fail("eager free failed");
+
+  int after_free = pgcount();
+  printf("pgcount eager after free = %d\n", after_free);
+  printf("pgcount eager free delta = %d\n", after_free - before);
+}
+
+static void
+lazy_test(void)
+{
+  int before = pgcount();
+  char *base = sbrklazy(2 * PGSIZE);
+  if (base == SBRK_ERROR)
+    fail("lazy sbrklazy failed");
+
+  int after_lazy_alloc = pgcount();
+  int delta_before_touch = after_lazy_alloc - before;
+
+  printf("pgcount lazy before = %d\n", before);
+  printf("pgcount lazy after reserve = %d\n", after_lazy_alloc);
+  printf("pgcount lazy delta before touch = %d\n", delta_before_touch);
+
+  if (delta_before_touch != 0)
+    fail("lazy reserve mapped pages before touch");
+
+  base[0] = 1;
+  int after_touch_one = pgcount();
+  int delta_after_one = after_touch_one - before;
+  printf("pgcount lazy delta after one touch = %d\n", delta_after_one);
+
+  if (delta_after_one != 1)
+    fail("lazy one-page touch delta is not 1");
+
+  base[PGSIZE] = 1;
+  int after_touch_two = pgcount();
+  int delta_after_two = after_touch_two - before;
+  printf("pgcount lazy delta after two touches = %d\n", delta_after_two);
+
+  if (delta_after_two != 2)
+    fail("lazy two-page touch delta is not 2");
+
+  if (sbrk(-2 * PGSIZE) == SBRK_ERROR)
+    fail("lazy free failed");
+
+  int after_free = pgcount();
+  printf("pgcount lazy after free = %d\n", after_free);
+}
+
+int
+main(int argc, char *argv[])
+{
+  (void)argc;
+  (void)argv;
+
+  align_break();
+  eager_test();
+  lazy_test();
+
+  printf("pgcounttest done\n");
+  exit(0);
+}
